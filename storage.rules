rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ===== Helper functions =====

    // 認証済みかどうか
    function isAuthenticated() {
      return request.auth != null;
    }

    // パスのuserIdが本人かどうか
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 画像ファイルかどうか
    function isImageFile() {
      return request.resource.contentType.matches('image/.*');
    }

    // 画像サイズ制限（5MB）
    function isValidImageSize() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // 書類サイズ制限（10MB・PDF等を許容）
    function isValidDocumentSize() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    // ===== 実装パスに対応したルール =====

    // 書類（請求書・車検証など機密情報）: documents/{userId}/{fileName}
    // 本人のみ読み書き可。PDF等の非画像も許容。
    match /documents/{userId}/{fileName} {
      allow read, delete: if isOwner(userId);
      allow write: if isOwner(userId) && isValidDocumentSize();
    }

    // SNS投稿画像: post_images/{userId}/{timestamp}/{fileName}
    // 投稿は公開コンテンツのため認証済みユーザーは閲覧可。書き込みは本人のみ。
    match /post_images/{userId}/{ts}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isImageFile() && isValidImageSize();
      allow delete: if isOwner(userId);
    }

    // 部品出品画像: user_part_listings/{userId}/{timestamp}/{fileName}
    // マーケットプレイスのため買い手（認証済み）も閲覧可。書き込みは本人のみ。
    match /user_part_listings/{userId}/{ts}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isImageFile() && isValidImageSize();
      allow delete: if isOwner(userId);
    }

    // プロフィール画像: profile_images/{fileName}（fileName = "{uid}_{timestamp}.jpg"）
    // 他ユーザーに表示されるため認証済みは閲覧可。
    // 書き込みはファイル名のプレフィックスが本人uidの場合のみ許可。
    match /profile_images/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && fileName.matches(request.auth.uid + '_.*')
                   && isImageFile() && isValidImageSize();
      allow delete: if isAuthenticated()
                    && fileName.matches(request.auth.uid + '_.*');
    }

    // 車両画像: vehicles/{userId}/{fileName}（fileName = "{uuid}.jpg"）
    // パスにuserIdを含めることで所有者単位のスコープが可能。
    // 書き込み・削除は本人のみ。閲覧は認証済みユーザー（他ユーザーへの表示を許容）。
    match /vehicles/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isImageFile() && isValidImageSize();
      allow delete: if isOwner(userId);
    }

    // 後方互換: 旧形式 vehicles/{fileName}（fileName = "{uuid}.jpg"）
    // 移行前に保存済みの画像URL（userId未スコープ）を閲覧できるようにする。
    // 新規書き込みは上の userId スコープ付きパスに限定するため read のみ許可。
    match /vehicles/{fileName} {
      allow read: if isAuthenticated();
      allow write, delete: if false;
    }

    // ===== デフォルト拒否 =====
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
