rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ユーザーが認証済みかどうか
    function isAuthenticated() {
      return request.auth != null;
    }

    // ファイルサイズ制限（5MB）
    function isValidFileSize() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // 画像ファイルかどうか
    function isImageFile() {
      return request.resource.contentType.matches('image/.*');
    }

    // ユーザーの車両画像（現行パス: vehicles/{userId}/{fileName}）
    // 読み取りは認証ユーザー全体: コミュニティ参考写真（明示同意済み）や
    // フリート表示で他ユーザーにも表示されるため。
    // 書き込みは本人のみ。
    match /vehicles/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidFileSize()
                   && isImageFile();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // 旧パス（vehicles/{userId}/{vehicleId}/{fileName}）の既存ファイル
    match /vehicles/{userId}/{vehicleId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidFileSize()
                   && isImageFile();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // SNS投稿画像（post_images/{userId}/{timestamp}/{fileName}）
    // 公開投稿に添付されるため読み取りは認証ユーザー全体
    match /post_images/{userId}/{ts}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidFileSize()
                   && isImageFile();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // プロフィール画像（profile_images/{userId}/{fileName}）
    // SNS上で他ユーザーにも表示されるため読み取りは認証ユーザー全体
    match /profile_images/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidFileSize()
                   && isImageFile();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // 書類（documents/{userId}/{fileName}）
    // 車検証等の個人情報を含むため本人のみ読み書き可能
    match /documents/{userId}/{fileName} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidFileSize();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // ユーザーのプロフィール画像（旧パス）
    match /users/{userId}/profile/{fileName} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidFileSize()
                   && isImageFile();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // メンテナンス記録の添付ファイル
    match /maintenance/{userId}/{recordId}/{fileName} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidFileSize();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // その他のファイルはデフォルトで拒否
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
