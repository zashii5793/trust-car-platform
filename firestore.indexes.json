{
  "indexes": [

    // =========================================================
    // vehicles
    // =========================================================
    {
      "collectionGroup": "vehicles",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    // =========================================================
    // maintenance_records
    // =========================================================
    {
      "collectionGroup": "maintenance_records",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "vehicleId", "order": "ASCENDING" },
        { "fieldPath": "date", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "maintenance_records",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "vehicleId", "order": "ASCENDING" },
        { "fieldPath": "type", "order": "ASCENDING" },
        { "fieldPath": "date", "order": "DESCENDING" }
      ]
    },

    // =========================================================
    // shops
    // =========================================================
    // 全店舗: isActive + 広告優先 + 評価順
    {
      "collectionGroup": "shops",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ASCENDING" },
        { "fieldPath": "isFeatured", "order": "DESCENDING" },
        { "fieldPath": "rating", "order": "DESCENDING" }
      ]
    },
    // 業種フィルタ: isActive + type + isFeatured
    {
      "collectionGroup": "shops",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ASCENDING" },
        { "fieldPath": "type", "order": "ASCENDING" },
        { "fieldPath": "isFeatured", "order": "DESCENDING" }
      ]
    },
    // 地域フィルタ: isActive + prefecture + isFeatured
    {
      "collectionGroup": "shops",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ASCENDING" },
        { "fieldPath": "prefecture", "order": "ASCENDING" },
        { "fieldPath": "isFeatured", "order": "DESCENDING" }
      ]
    },
    // 注目店舗のみ: isActive + isFeatured + rating
    {
      "collectionGroup": "shops",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ASCENDING" },
        { "fieldPath": "isFeatured", "order": "ASCENDING" },
        { "fieldPath": "rating", "order": "DESCENDING" }
      ]
    },
    // サービスカテゴリ: isActive + services(array) + rating
    {
      "collectionGroup": "shops",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ASCENDING" },
        { "fieldPath": "services", "arrayConfig": "CONTAINS" },
        { "fieldPath": "rating", "order": "DESCENDING" }
      ]
    },
    // 対応メーカー: isActive + supportedMakerIds(array) + rating
    {
      "collectionGroup": "shops",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ASCENDING" },
        { "fieldPath": "supportedMakerIds", "arrayConfig": "CONTAINS" },
        { "fieldPath": "rating", "order": "DESCENDING" }
      ]
    },

    // =========================================================
    // part_listings
    // =========================================================
    // おすすめパーツ: isActive + isFeatured + rating
    {
      "collectionGroup": "part_listings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ASCENDING" },
        { "fieldPath": "isFeatured", "order": "DESCENDING" },
        { "fieldPath": "rating", "order": "DESCENDING" }
      ]
    },
    // カテゴリ絞り込み: isActive + category + isFeatured + rating
    {
      "collectionGroup": "part_listings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ASCENDING" },
        { "fieldPath": "category", "order": "ASCENDING" },
        { "fieldPath": "isFeatured", "order": "DESCENDING" },
        { "fieldPath": "rating", "order": "DESCENDING" }
      ]
    },
    // 注目パーツ: isActive + isFeatured(==true) + rating
    {
      "collectionGroup": "part_listings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ASCENDING" },
        { "fieldPath": "isFeatured", "order": "ASCENDING" },
        { "fieldPath": "rating", "order": "DESCENDING" }
      ]
    },
    // タグ検索: isActive + tags(array) + rating
    {
      "collectionGroup": "part_listings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ASCENDING" },
        { "fieldPath": "tags", "arrayConfig": "CONTAINS" },
        { "fieldPath": "rating", "order": "DESCENDING" }
      ]
    },

    // =========================================================
    // inquiries
    // =========================================================
    // ユーザー問い合わせ一覧
    {
      "collectionGroup": "inquiries",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },
    // 店舗問い合わせ一覧
    {
      "collectionGroup": "inquiries",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "shopId", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },
    // ユーザー未読カウント
    {
      "collectionGroup": "inquiries",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "unreadCountUser", "order": "DESCENDING" }
      ]
    },

    // =========================================================
    // posts (SNS)
    // =========================================================
    // 全公開フィード
    {
      "collectionGroup": "posts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "visibility", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // カテゴリフィルタ付きフィード
    {
      "collectionGroup": "posts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "visibility", "order": "ASCENDING" },
        { "fieldPath": "category", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // ユーザー自身の投稿
    {
      "collectionGroup": "posts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // ハッシュタグ検索
    {
      "collectionGroup": "posts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "hashtags", "arrayConfig": "CONTAINS" },
        { "fieldPath": "visibility", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    // =========================================================
    // comments
    // =========================================================
    {
      "collectionGroup": "comments",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "postId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "ASCENDING" }
      ]
    },

    // =========================================================
    // notifications
    // =========================================================
    {
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "isRead", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    // =========================================================
    // drive_logs
    // =========================================================
    // ユーザーのドライブ履歴（startTime: モデルの正しいフィールド名）
    {
      "collectionGroup": "drive_logs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "startTime", "order": "DESCENDING" }
      ]
    },
    // 公開ドライブフィード: isPublic + status + createdAt
    {
      "collectionGroup": "drive_logs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isPublic", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // ユーザーの完了ドライブ数カウント用
    {
      "collectionGroup": "drive_logs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },

    // =========================================================
    // drive_waypoints
    // =========================================================
    {
      "collectionGroup": "drive_waypoints",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "driveLogId", "order": "ASCENDING" },
        { "fieldPath": "timestamp", "order": "ASCENDING" }
      ]
    },

    // =========================================================
    // spots (ドライブスポット)
    // =========================================================
    {
      "collectionGroup": "spots",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isPublic", "order": "ASCENDING" },
        { "fieldPath": "name", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "spots",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isPublic", "order": "ASCENDING" },
        { "fieldPath": "visitCount", "order": "DESCENDING" }
      ]
    },

    // =========================================================
    // spot_ratings / spot_favorites / spot_visits
    // =========================================================
    {
      "collectionGroup": "spot_ratings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "spotId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "spot_favorites",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "spot_visits",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "visitedAt", "order": "DESCENDING" }
      ]
    }

  ],
  "fieldOverrides": []
}
