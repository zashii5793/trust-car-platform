{
  "name": "trust-car-platform-storage-rules-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Firebase Storage / Firestore セキュリティルールの自動テスト（@firebase/rules-unit-testing + Emulator）",
  "scripts": {
    "test": "firebase emulators:exec --only storage,firestore --project trust-car-platform \"jest --runInBand\"",
    "test:watch": "firebase emulators:exec --only storage,firestore --project trust-car-platform \"jest --runInBand --watch\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.0.0",
    "jest": "^29.7.0"
  }
}
