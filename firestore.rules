rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==================== MULTI-TENANT SECURITY MODEL ====================
    // BtoB tenant isolation:
    //   - Each shop's ID equals the owner's Firebase Auth UID (shopId == ownerId == uid)
    //   - Shop public data (name, type, planType) is readable by all authenticated users
    //     to support the marketplace browsing experience
    //   - Shop private data (analytics, revenue, private ops) lives in sub-collections
    //     accessible only to the shop owner (isShopOwner helper)
    //   - Inter-shop data leakage is prevented by ownerId checks on all write operations
    //   - Inquiry data is restricted to the specific shop+user pair involved
    // =====================================================================

    // ユーザーが認証済みかどうか
    function isAuthenticated() {
      return request.auth != null;
    }

    // 自分自身のデータかどうか
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ドキュメントの所有者かどうか（userId フィールドで判定）
    function isDocumentOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 作成時に自分のユーザーIDを設定しているか
    function isCreatingOwnDocument() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Checks if the requesting user is the owner of a specific shop
    // In this schema, shopId == ownerId == request.auth.uid
    function isShopOwner(shopId) {
      return isAuthenticated() && request.auth.uid == shopId;
    }

    // Checks if the requesting user is an author of a newsletter
    function isNewsletterAuthor() {
      return isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // ユーザードキュメント
    match /users/{userId} {
      // 自分のデータのみ読み取り可能
      allow read: if isOwner(userId);

      // 作成: 自分自身のドキュメントのみ
      allow create: if isOwner(userId);

      // 更新: planType / planExpiresAt はCloud Functions経由のみ（クライアント書き換え禁止）
      allow update: if isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['planType', 'planExpiresAt']);
    }

    // 車両データ
    match /vehicles/{vehicleId} {
      // 自分の車両のみ読み取り可能
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // 作成時は自分のユーザーIDを設定していること
      allow create: if isCreatingOwnDocument();

      // 更新・削除は所有者のみ
      allow update, delete: if isDocumentOwner();

      // 走行距離の更新履歴（監査用途のため不変: 作成のみ・更新/削除不可）
      match /mileage_history/{recordId} {
        function ownsParentVehicle() {
          return isAuthenticated()
              && get(/databases/$(database)/documents/vehicles/$(vehicleId))
                  .data.userId == request.auth.uid;
        }
        allow read: if ownsParentVehicle();
        allow create: if ownsParentVehicle()
            && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }

      // 交換目安のユーザー設定（車両の所有者のみ読み書き可能）
      match /maintenance_prefs/{docId} {
        function ownsParentVehicleForPrefs() {
          return isAuthenticated()
              && get(/databases/$(database)/documents/vehicles/$(vehicleId))
                  .data.userId == request.auth.uid;
        }
        allow read: if ownsParentVehicleForPrefs();
        allow write: if ownsParentVehicleForPrefs()
            && request.resource.data.userId == request.auth.uid;
      }
    }

    // メンテナンス記録
    match /maintenance_records/{recordId} {
      // 自分の記録のみ読み取り可能
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // 作成時は自分のユーザーIDを設定していること
      allow create: if isCreatingOwnDocument();

      // 更新・削除は所有者のみ
      allow update, delete: if isDocumentOwner();
    }

    // 通知データ
    match /notifications/{notificationId} {
      // 自分の通知のみ読み取り可能
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // 作成時は自分のユーザーIDを設定していること
      allow create: if isCreatingOwnDocument();

      // 更新・削除は所有者のみ
      allow update, delete: if isDocumentOwner();
    }

    // 請求書データ (Phase 5)
    match /invoices/{invoiceId} {
      // 自分の請求書のみ読み取り可能
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // 作成時は自分のユーザーIDを設定していること
      allow create: if isCreatingOwnDocument();

      // 更新・削除は所有者のみ
      allow update, delete: if isDocumentOwner();
    }

    // 書類データ (Phase 5)
    match /documents/{documentId} {
      // 自分の書類のみ読み取り可能
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // 作成時は自分のユーザーIDを設定していること
      allow create: if isCreatingOwnDocument();

      // 更新・削除は所有者のみ
      allow update, delete: if isDocumentOwner();
    }

    // サービスメニューデータ (Phase 5)
    match /service_menus/{menuId} {
      // 有効なメニューは認証済みユーザーなら誰でも読み取り可能
      allow read: if isAuthenticated();

      // 作成は自店舗のメニューのみ（shopId == 自分のUID）
      allow create: if isAuthenticated() &&
        request.resource.data.shopId == request.auth.uid;
      // 更新・削除は自店舗のメニューのみ
      allow update, delete: if isAuthenticated() &&
        resource.data.shopId == request.auth.uid;
    }

    // 店舗データ (BtoB Marketplace)
    match /shops/{shopId} {
      // 認証済みユーザーなら誰でも閲覧可能（アクティブな店舗）
      allow read: if isAuthenticated();

      // 新規作成: docId == uid、かつ ownerId フィールドも uid と一致
      allow create: if isAuthenticated()
        && shopId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;

      // 通常更新: オーナー本人のみ（subscriptionStatus / planType は除外 — Cloud Functions経由）
      allow update: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['subscriptionStatus', 'revenueCatUserId', 'trialStartedAt']);

      // 削除: オーナー本人のみ
      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;

      // Shop private sub-collection: analytics, revenue, sensitive ops data
      // Only the shop owner can read/write — never exposed to other users
      match /private/{docId} {
        allow read, write: if isShopOwner(shopId);
      }

      // 施工事例サブコレクション（ショッププロフィールの公開情報）
      match /caseStudies/{caseStudyId} {
        // 認証済みユーザーなら誰でも閲覧可能（店舗の公開情報の一部）
        allow read: if isAuthenticated();
        // 作成はオーナーのみ、かつ shopId フィールドが一致すること
        allow create: if isShopOwner(shopId) &&
          request.resource.data.shopId == shopId;
        // 更新・削除はオーナーのみ
        allow update, delete: if isShopOwner(shopId);
      }
    }

    // ユーザー出品パーツリスティング (C2C Marketplace)
    match /user_part_listings/{listingId} {
      // 認証済みユーザーなら誰でも閲覧可能
      allow read: if isAuthenticated();

      // 作成: 自分の sellerId でのみ作成可能
      allow create: if isAuthenticated()
        && request.resource.data.sellerId == request.auth.uid;

      // 更新・削除: 出品者本人のみ
      allow update, delete: if isAuthenticated()
        && resource.data.sellerId == request.auth.uid;
    }

    // パーツリスティングデータ (BtoB Marketplace)
    match /part_listings/{listingId} {
      // 有効なリスティングは認証済みユーザーなら誰でも閲覧可能
      allow read: if isAuthenticated();

      // リスティングの作成・更新・削除は店舗オーナーのみ
      allow create: if isAuthenticated() &&
        request.resource.data.shopId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.shopId == request.auth.uid;
    }

    // 問い合わせデータ (BtoB Marketplace)
    match /inquiries/{inquiryId} {
      // ショップオーナー（shopId）とユーザー本人（userId）が読み取り可能
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.userId
            || request.auth.uid == resource.data.shopId);

      // 認証済みユーザーが作成可能（自分の userId を設定していること）
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;

      // 更新はオーナーまたはユーザー本人（既読フラグ等の更新用）
      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.userId
            || request.auth.uid == resource.data.shopId);

      // 削除は本人のみ
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.userId;

      // 問い合わせ内のメッセージ
      match /messages/{messageId} {
        // メッセージは送信者または受信者（inquiryの当事者）のみ閲覧可能
        allow read: if isAuthenticated() &&
          (resource.data.senderId == request.auth.uid ||
           resource.data.receiverId == request.auth.uid);

        // メッセージ作成は送信者が自分であること
        allow create: if isAuthenticated() &&
          request.resource.data.senderId == request.auth.uid;

        // 更新は既読フラグのみ（受信者のみ）
        allow update: if isAuthenticated() &&
          resource.data.receiverId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);

        // 削除は不可
        allow delete: if false;
      }
    }

    // 車両マスターデータ (読み取り専用)
    match /vehicle_masters/{docType} {
      allow read: if isAuthenticated();
      allow write: if false;  // 管理者のみ（別途管理画面から更新）

      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // ==================== SNS/コミュニティ機能 ====================

    // 投稿データ
    match /posts/{postId} {
      // 公開投稿: 認証済みユーザーなら誰でも閲覧可能。
      // フォロワー限定: 投稿者をフォロー中のユーザーのみ
      //   (follows/{viewerUid}_{authorUid} ドキュメントの存在で確認)。
      // 非公開: 本人のみ。
      // クライアント側フィルタだけでは SDK 直接クエリで全件取得できてしまうため
      // ルールで強制する。クエリは必ず visibility か userId に条件を含めること。
      allow read: if isAuthenticated() &&
        (resource.data.visibility == 'public' ||
         resource.data.userId == request.auth.uid ||
         (resource.data.visibility == 'followers' &&
          exists(/databases/$(database)/documents/follows/$(request.auth.uid + '_' + resource.data.userId))));

      // 作成時は自分のユーザーIDを設定していること
      allow create: if isCreatingOwnDocument();

      // 更新・削除は所有者のみ
      allow update, delete: if isDocumentOwner();
    }

    // コメントデータ
    match /comments/{commentId} {
      // コメントは認証済みユーザーなら誰でも閲覧可能
      allow read: if isAuthenticated();

      // 作成時は自分のユーザーIDを設定していること
      allow create: if isCreatingOwnDocument();

      // 更新・削除は所有者のみ
      allow update, delete: if isDocumentOwner();
    }

    // 投稿へのいいね
    match /post_likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow update: if false;  // いいねの更新は不可
    }

    // コメントへのいいね
    match /comment_likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // フォロー関係
    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.followerId == request.auth.uid;
      allow update: if false;  // フォロー関係の更新は不可
    }

    // ユーザープロフィール（SNS用）
    match /user_profiles/{userId} {
      // プロフィールは認証済みユーザーなら誰でも閲覧可能
      allow read: if isAuthenticated();

      // 更新は自分自身のみ
      allow create, update: if isOwner(userId);
      allow delete: if false;  // プロフィール削除は不可
    }

    // SNS通知
    match /social_notifications/{notificationId} {
      // 自分の通知のみ閲覧可能
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      // 通知作成は認証済みユーザー。actorId は必ず本人 — 他人になりすました
      // 偽通知（フィッシング誘導等）を防ぐ
      allow create: if isAuthenticated() &&
        request.resource.data.actorId == request.auth.uid &&
        request.resource.data.isRead == false;

      // 既読フラグの更新のみ許可
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      allow delete: if false;
    }

    // ==================== 車両購入レコメンド ====================

    // 車両リスティング（販売情報）
    match /vehicle_listings/{listingId} {
      // アクティブなリスティングは認証済みユーザーなら誰でも閲覧可能
      allow read: if isAuthenticated();

      // 作成時は自分のユーザーIDかつ sellerId も本人であること
      // （update/delete が sellerId で判定されるため不整合を防ぐ）
      allow create: if isCreatingOwnDocument() &&
        request.resource.data.sellerId == request.auth.uid;

      // 更新は出品者のみ（sellerId）
      allow update: if isAuthenticated() &&
        resource.data.sellerId == request.auth.uid;

      // 削除は出品者のみ
      allow delete: if isAuthenticated() &&
        resource.data.sellerId == request.auth.uid;
    }

    // お気に入り
    match /listing_favorites/{favoriteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ユーザーの車両購入設定
    match /vehicle_preferences/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // ==================== ドライブログ/マップ機能 ====================

    // ドライブログ
    match /drive_logs/{logId} {
      // 公開ログは認証済みユーザーなら誰でも閲覧可能
      // 非公開ログは所有者のみ
      allow read: if isAuthenticated() &&
        (resource.data.isPublic == true || resource.data.userId == request.auth.uid);

      // 作成時は自分のユーザーIDを設定していること
      allow create: if isCreatingOwnDocument();

      // 更新・削除は所有者のみ
      allow update, delete: if isDocumentOwner();
    }

    // ウェイポイント（GPSポイント）
    match /drive_waypoints/{waypointId} {
      // ウェイポイントは自分のデータのみアクセス可能（位置情報はプライバシー最優先）
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ドライブログへのいいね
    match /drive_log_likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // スポット（観光地・立ち寄り地点）
    match /spots/{spotId} {
      // 公開スポットは認証済みユーザーなら誰でも閲覧可能
      allow read: if isAuthenticated() &&
        (resource.data.isPublic == true || resource.data.userId == request.auth.uid);

      // 作成時は自分のユーザーIDを設定していること
      allow create: if isCreatingOwnDocument();

      // 更新・削除は所有者のみ
      allow update, delete: if isDocumentOwner();
    }

    // スポット評価・レビュー
    match /spot_ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      // 自分のレビューのみ更新・削除可能
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // スポットお気に入り
    match /spot_favorites/{favoriteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // スポット訪問記録
    match /spot_visits/{visitId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      // 自分の訪問記録のみ更新・削除可能
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ==================== ニュースレター ====================

    // ニュースレター本体（作成・配信はショップオーナーのみ）
    match /newsletters/{newsletterId} {
      // 配信済みは認証済みユーザー全員が閲覧可能、下書きは著者のみ
      allow read: if isAuthenticated() &&
        (resource.data.status == "sent" ||
         resource.data.authorId == request.auth.uid);

      // 作成: authorId == 自分
      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid;

      // 更新: 著者のみ（status="scheduled" への変更はCloud Functions経由で実質管理）
      allow update: if isAuthenticated() &&
        resource.data.authorId == request.auth.uid;

      // 削除: 著者のみ（送信済みは削除不可）
      allow delete: if isAuthenticated() &&
        resource.data.authorId == request.auth.uid &&
        resource.data.status != "sent";
    }

    // ニュースレター購読設定（ユーザー自身のみ読み書き可能）
    match /newsletter_subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Monthly performance reports generated by Cloud Functions
    // Only the shop owner can read; write is Cloud Functions only
    match /shop_monthly_reports/{shopId} {
      allow read: if isShopOwner(shopId);
      allow write: if false; // written exclusively by Cloud Functions
    }

    // Shop analytics events (page views, inquiry click-throughs)
    match /shop_analytics/{shopId} {
      allow read: if isShopOwner(shopId);
      allow write: if false; // written exclusively by Cloud Functions
    }

    // ==================== AIチャット利用量カウンター ====================
    // ai_chat_usage/{userId}/daily/{YYYY-MM-DD}
    // Written exclusively by the askCarAi Cloud Function (server-side).
    // Users can read their own usage so the UI can show remaining quota.
    match /ai_chat_usage/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // written exclusively by Cloud Functions

      match /daily/{date} {
        allow read: if isOwner(userId);
        allow write: if false; // written exclusively by Cloud Functions
      }
    }

    // ==================== コミュニティ車種グレード仕様データ ====================
    // vehicle_grade_specs/{specId}
    // Anyone can read; authenticated users can create with a strict schema.
    // Updates may only add the caller once to contributorIds (badge counts
    // cannot be inflated), keep contributorCount consistent, and backfill
    // the sample photo when none exists yet — the first contributor's spec
    // data stays the source of truth.
    match /vehicle_grade_specs/{specId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasOnly([
             'maker', 'model', 'year', 'grade',
             'engineDisplacement', 'fuelType',
             'seatingCapacity', 'vehicleWeight', 'standardEquipment',
             'sampleImageUrl', 'contributorIds', 'contributorCount',
             'updatedAt'
           ])
        && request.resource.data.maker is string
        && request.resource.data.model is string
        && request.resource.data.year is int
        && request.resource.data.contributorIds == [request.auth.uid]
        && request.resource.data.contributorCount == 1;
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['contributorIds', 'contributorCount',
                       'sampleImageUrl', 'updatedAt'])
        // Caller may only append themselves, exactly once.
        && !(request.auth.uid in resource.data.get('contributorIds', []))
        && request.resource.data.contributorIds
             == resource.data.get('contributorIds', []).concat([request.auth.uid])
        && request.resource.data.contributorCount
             == resource.data.get('contributorCount', 0) + 1
        // Photo may only be backfilled while none exists.
        && (!('sampleImageUrl' in request.resource.data.diff(resource.data).affectedKeys())
            || resource.data.get('sampleImageUrl', null) == null);
    }

    // ==================== フリートメンバー管理 ====================
    // Returns true if the authenticated user holds the 'admin' role in [companyId].
    function isFleetAdminOf(companyId) {
      let id = companyId + '_' + request.auth.uid;
      return exists(/databases/$(database)/documents/fleet_members/$(id)) &&
        get(/databases/$(database)/documents/fleet_members/$(id)).data.role == 'admin';
    }

    // fleet_members/{companyId}_{userId}
    // Document ID format: {companyId}_{userId}
    // Company owner (companyId == request.auth.uid) or admin has member management access.
    // Members may read their own record and all records in their company.
    match /fleet_members/{memberId} {
      // Owner or admin reads all company members; members read their own record.
      allow read: if isAuthenticated() && (
        resource.data.companyId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        isFleetAdminOf(resource.data.companyId)
      );

      // Owner or admin can add members (role restrictions enforced at service layer).
      allow create: if isAuthenticated() && (
        request.resource.data.companyId == request.auth.uid ||
        isFleetAdminOf(request.resource.data.companyId)
      );

      // Owner or admin can update roles (owner-role guard enforced at service layer).
      allow update: if isAuthenticated() && (
        resource.data.companyId == request.auth.uid ||
        isFleetAdminOf(resource.data.companyId)
      );

      // Owner or admin can remove members; members can remove themselves.
      // Admin cannot remove owner — enforced at service layer.
      allow delete: if isAuthenticated() && (
        resource.data.companyId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        isFleetAdminOf(resource.data.companyId)
      );
    }

    // ==================== アクセサリーショーケース ====================
    // accessory_showcases/{showcaseId}
    // Community-contributed showcase posts (dashcam, tire, etc.)
    // Anyone authenticated may read; only the creator may write/delete.
    match /accessory_showcases/{showcaseId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ==================== 中古車購入問い合わせ ====================
    // car_purchase_inquiries/{inquiryId}
    // Created by buyers; readable by the buyer and the target shop.
    match /car_purchase_inquiries/{inquiryId} {
      // Buyer and target shop can read.
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         resource.data.shopId == request.auth.uid);

      // Any authenticated user can create with their own userId.
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      // Only the buyer can update (e.g., close the inquiry).
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      // Buyer can delete their own inquiry.
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ==================== 安全情報 ====================
    // safety_tips/{tipId}
    // Official safety information from JAF/NPA/MLIT/FDMA/ITARDA.
    // Read-only for all authenticated users.
    // Write is handled exclusively by Cloud Functions / admin SDK.
    match /safety_tips/{tipId} {
      allow read: if isAuthenticated();
      allow write: if false; // admin SDK only
    }

    // ==================== コミュニティ整備トレンド ====================
    // community_maintenance_trends/{docId}
    // Aggregated maintenance statistics keyed by "{maker}_{model}".
    // Only pre-aggregated, anonymised values — no individual user data.
    // Read: any authenticated user.  Write: admin SDK only.
    match /community_maintenance_trends/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // admin SDK only — seeded via seed_community_trends.js
    }

    // ==================== 店舗チェーン ====================
    // shop_chains/{chainId}
    // Franchise chain master data (e.g., コバック, ジェームス).
    // Read: any authenticated user.
    // Create: any shop owner (ownerId == request.auth.uid).
    // Update/Delete: only the chain creator (ownerId field).
    match /shop_chains/{chainId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.get('ownerId', '') == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        resource.data.get('ownerId', '') == request.auth.uid;
    }

    // その他のドキュメントはデフォルトで拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
